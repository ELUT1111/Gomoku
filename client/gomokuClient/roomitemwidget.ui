  <property name="styleSheet">
   <string notr="true">
/* 主卡片：圆角、阴影、白底、悬浮高亮 */
QWidget#RoomItemWidget {
    background-color: #FFFFFF;
    border-radius: 12px;
    padding: 16px 20px;
    border: 1px solid #F0F2F5;
}
QWidget#RoomItemWidget:hover {
    border-color: #4A6CF7;
    background-color: #FAFCFF;
}
/* 通用文字 */
QLabel {
    font-family: "Microsoft YaHei";
    font-size: 15px;
    color: #333333;
}
/* 房间号：加粗突出 */
QLabel#lblRoomId {
    font-size: 16px;
    font-weight: bold;
    color: #2A2A2A;
    min-width: 180px;
}
/* 状态标签：带背景色的胶囊样式 */
QLabel#lblStatus {
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 13px;
    font-weight: bold;
    min-width: 100px;
}
/* 人数标签 */
QLabel#lblPlayerCount {
    color: #666666;
    min-width: 120px;
}
/* 加入按钮：主色渐变，强化交互 */
QPushButton#btnJoin {
    background: qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #4A6CF7, stop:1 #35D8A6);
    color: white;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    padding: 8px 24px;
    border: none;
    min-width: 100px;
}
QPushButton#btnJoin:hover:enabled {
    background: qlineargradient(x1:0,y1:0,x2:1,y2:0, stop:0 #3A5CE7, stop:1 #2BC896);
}
QPushButton#btnJoin:pressed {
    padding: 9px 24px 7px;
}
QPushButton#btnJoin:disabled {
    background: #CCCCCC;
    color: #999999;
}
</string>
