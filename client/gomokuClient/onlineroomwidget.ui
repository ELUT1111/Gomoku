  <property name="styleSheet">
   <string notr="true">
    /* 全局样式 */
    QWidget {
     background-color: #F5F7FA;
     font-family: "Microsoft YaHei";
     font-size: 14px;
    }
    /* 标题栏样式 */
    QFrame#frameTitle {
     background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #4A6CF7, stop:1 #35D8A6);
     border-radius: 12px 12px 0 0;
     color: white;
    }
    /* 玩家卡片样式 */
    QFrame#cardHost, QFrame#cardOpponent {
     background-color: white;
     border-radius: 10px;
     box-shadow: 0 2px 8px rgba(0,0,0,0.08);
     border: 1px solid #EEEEEE;
    }
    /* 卡片标题 */
    QLabel#lblHostTitle, QLabel#lblOpponentTitle {
     font-size: 16px;
     font-weight: bold;
     color: #333333;
    }
    /* 信息文本 */
    QLabel#lblHostId, QLabel#lblOpponentId, QLabel#lblHostChess, QLabel#lblOpponentChess {
     color: #666666;
    }
    /* 状态文本 */
    QLabel#lblHostStatus, QLabel#lblOpponentStatus {
     font-size: 13px;
    }
    QLabel#lblHostStatus {
     color: #4A6CF7;
    }
    QLabel#lblOpponentStatus {
     color: #FF6B6B;
    }
    /* 按钮通用样式 */
    QPushButton {
     border-radius: 8px;
     font-size: 14px;
     height: 40px;
     border: none;
    }
    /* 主按钮（开始游戏） */
    QPushButton#btnStartGame {
     background-color: #4A6CF7;
     color: white;
    }
    QPushButton#btnStartGame:disabled {
     background-color: #CCCCCC;
     color: #999999;
    }
    QPushButton#btnStartGame:hover {
     background-color: #3A5CE7;
    }
    /* 次要按钮（复制/退出） */
    QPushButton#btnCopyRoomId, QPushButton#btnQuitRoom {
     background-color: white;
     color: #666666;
     border: 1px solid #EEEEEE;
    }
    QPushButton#btnCopyRoomId:hover, QPushButton#btnQuitRoom:hover {
     background-color: #F8F8F8;
     color: #333333;
    }
    /* 状态提示 */
    QLabel#lblRoomStatus {
     font-size: 18px;
     font-weight: bold;
     color: #4A6CF7;
    }
   </string>
  </property>
