   <string notr="true">
    /* 全局基础样式 */
    QWidget {
     background-color: #F5F7FA;
     font-family: &quot;Microsoft YaHei&quot;;
     font-size: 14px;
    }
    /* 分组框样式：卡片化、圆角、阴影 */
    QGroupBox#groupBox_3 {
     border: none;
     background-color: white;
     border-radius: 12px;
     margin-top: 10px;
     padding-top: 20px;
    }
    /* 分组框标题（隐藏，保持布局） */
    QGroupBox#groupBox_3::title {
     subcontrol-origin: margin;
     subcontrol-position: top center;
     padding: 0 10px;
     color: transparent;
    }
    /* 按钮通用样式 */
    QPushButton {
     border-radius: 8px;
     border: none;
     font-size: 15px;
     height: 45px;
     margin: 8px 15px;
    }
    /* 主功能按钮（离线/在线） */
    QPushButton#offlineButton, QPushButton#onlineButton {
     background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #4A6CF7, stop:1 #35D8A6);
     color: white;
    }
    QPushButton#offlineButton:hover, QPushButton#onlineButton:hover {
     background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #3A5CE7, stop:1 #2BC896);
    }
    /* 次要按钮（退出） */
    QPushButton#quitButton {
     background-color: white;
     color: #666666;
     border: 1px solid #EEEEEE;
     font-size: 12px;
    }
    QPushButton#quitButton:hover {
     background-color: #F8F8F8;
     color: #FF6B6B;
     border-color: #FFE6E6;
    }
