  <property name="styleSheet">
   <string notr="true">
    /* 主窗口全局样式 */
    QMainWindow {
     background-color: #F5F7FA;
     border: none;
    }
    QMainWindow::centralWidget {
     border: none;
     margin: 10px; /* 预留边框空间，方便拓展 */
    }
    /* 核心容器：圆角+轻微阴影，提升美观度 */
    QWidget#centralwidget {
     background-color: white;
     border-radius: 12px;
     padding: 5px;
    }
    /* 页面切换容器：QStackedWidget 优化 */
    QStackedWidget#stackedWidget {
     border: none;
     background-color: transparent;
    }
    /* 所有页面容器：透明背景，统一视觉 */
    QWidget#startPage, QWidget#offlineChoicePage, QWidget#onlineChoicePage, QWidget#onlineRoomPage, QWidget#gamePage {
     background-color: transparent;
    }
    /* 游戏页面按钮栏样式：与整套风格统一 */
    QPushButton#undoButton, QPushButton#resetButton {
     border-radius: 8px;
     border: none;
     font-size: 11px;
     height: 36px;
     padding: 0 20px;
     margin: 0 5px;
     background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #4A6CF7, stop:1 #35D8A6);
     color: white;
    }
    QPushButton#undoButton:hover, QPushButton#resetButton:hover {
     background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #3A5CE7, stop:1 #2BC896);
    }
    QPushButton#backButton {
     border-radius: 8px;
     border: none;
     font-size: 11px;
     height: 36px;
     padding: 0 20px;
     margin: 0 5px;
     background-color: white;
     color: #666666;
     border: 1px solid #EEEEEE;
    }
    QPushButton#backButton:hover {
     background-color: #F8F8F8;
     color: #FF6B6B;
     border-color: #FFE6E6;
    }
    /* 游戏按钮栏容器：统一间距，美化底部 */
    QWidget#widget_2 {
     background-color: #F5F7FA;
     border-radius: 8px;
     margin: 5px;
    }
    QHBoxLayout#gameLayout_bar {
     justify-content: center; /* 按钮居中，视觉更协调 */
     spacing: 15px; /* 按钮间距优化 */
     padding: 5px 0;
    }
   </string>
