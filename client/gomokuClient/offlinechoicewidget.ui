   <string notr="true">
    /* 全局基础样式 */
    QWidget {
     background-color: #F5F7FA;
     font-family: &quot;Microsoft YaHei&quot;;
     font-size: 14px;
    }
    /* 分组框样式：卡片化、圆角、阴影 */
    QGroupBox#groupBox_3 {
     border: none;
     background-color: white;
     border-radius: 12px;
     margin-top: 10px;
     padding-top: 15px;
    }
    /* 分组框标题（隐藏） */
    QGroupBox#groupBox_3::title {
     subcontrol-origin: margin;
     subcontrol-position: top center;
     padding: 0 10px;
     color: transparent;
    }
    /* 功能按钮通用样式（自由练习/人机难度） */
    QPushButton {
     border-radius: 8px;
     border: none;
     font-size: 15px;
     height: 38px;
     margin: 6px 15px;
    }
    /* 核心功能按钮（自由练习/人机难度） */
    QPushButton#freeButton, QPushButton#easyButton, QPushButton#normalButton, QPushButton#hardButton {
     background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #4A6CF7, stop:1 #35D8A6);
     color: white;
    }
    QPushButton#freeButton:hover, QPushButton#easyButton:hover, QPushButton#normalButton:hover, QPushButton#hardButton:hover {
     background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #3A5CE7, stop:1 #2BC896);
    }
    /* 次要按钮（返回） */
    QPushButton#returnButton {
     background-color: white;
     color: #666666;
     border: 1px solid #EEEEEE;
     font-size: 12px;
    }
    QPushButton#returnButton:hover {
     background-color: #F8F8F8;
     color: #FF6B6B;
     border-color: #FFE6E6;
    }
    /* 标题样式 */
    QLabel#lblOfflineTitle {
     font-size: 22px;
     font-weight: bold;
     color: #4A6CF7;
     alignment: center;
    }
   </string>
